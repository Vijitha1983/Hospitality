{
  "name": "Banquet Booking",
  "module": "Shared",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "BNQ-.YYYY.-.#####",
  "title_field": "event_name",
  "fields": [
    {"fieldname": "event_name", "fieldtype": "Data", "label": "Event Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "event_type", "fieldtype": "Select", "label": "Event Type", "reqd": 1,
      "options": "\nWedding\nCorporate\nBirthday\nConference\nSocial\nOther", "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status",
      "options": "\nTentative\nConfirmed\nCancelled\nCompleted", "default": "Tentative", "in_list_view": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "guest", "fieldtype": "Link", "label": "Guest / Contact", "options": "Guest"},
    {"fieldname": "contact_name", "fieldtype": "Data", "label": "Contact Person", "reqd": 1},
    {"fieldname": "contact_phone", "fieldtype": "Data", "label": "Phone"},
    {"fieldname": "contact_email", "fieldtype": "Data", "label": "Email"},
    {"fieldname": "section_event", "fieldtype": "Section Break", "label": "Event Details"},
    {"fieldname": "venue", "fieldtype": "Link", "label": "Venue / Hall", "options": "Outlet", "reqd": 1},
    {"fieldname": "event_date", "fieldtype": "Date", "label": "Event Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "start_time", "fieldtype": "Time", "label": "Start Time", "reqd": 1},
    {"fieldname": "end_time", "fieldtype": "Time", "label": "End Time", "reqd": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "pax", "fieldtype": "Int", "label": "Pax (Guests)", "reqd": 1},
    {"fieldname": "setup_type", "fieldtype": "Select", "label": "Setup Type",
      "options": "\nTheatre\nClassroom\nBanquet Rounds\nU-Shape\nCocktail\nCustom"},
    {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
    {"fieldname": "section_packages", "fieldtype": "Section Break", "label": "Packages & Services"},
    {"fieldname": "package_items", "fieldtype": "Table", "label": "Package Items", "options": "Banquet Package Item"},
    {"fieldname": "section_billing", "fieldtype": "Section Break", "label": "Billing"},
    {"fieldname": "advance_amount", "fieldtype": "Currency", "label": "Advance Amount"},
    {"fieldname": "advance_paid", "fieldtype": "Currency", "label": "Advance Paid", "read_only": 1},
    {"fieldname": "col_break_3", "fieldtype": "Column Break"},
    {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1},
    {"fieldname": "balance_due", "fieldtype": "Currency", "label": "Balance Due", "read_only": 1},
    {"fieldname": "sales_invoice", "fieldtype": "Link", "label": "Sales Invoice", "options": "Sales Invoice", "read_only": 1},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "special_requirements", "fieldtype": "Text", "label": "Special Requirements"},
    {"fieldname": "internal_notes", "fieldtype": "Text", "label": "Internal Notes"},
    {"fieldname": "cancellation_reason", "fieldtype": "Text", "label": "Cancellation Reason"}
  ],
  "permissions": [
    {"role": "Hotel Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
    {"role": "Hotel User", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1}
  ],
  "track_changes": 1
}
