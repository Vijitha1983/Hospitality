{
  "name": "Hotel Check-in",
  "module": "Hotel",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "CI-.YYYY.-.#####",
  "title_field": "guest",
  "fields": [
    {"fieldname": "booking", "fieldtype": "Link", "label": "Booking", "reqd": 1, "options": "Hotel Booking", "in_list_view": 1},
    {"fieldname": "guest", "fieldtype": "Link", "label": "Guest", "reqd": 1, "options": "Guest", "read_only": 1, "in_list_view": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "room", "fieldtype": "Link", "label": "Room", "reqd": 1, "options": "Room", "in_list_view": 1},
    {"fieldname": "actual_checkin", "fieldtype": "Datetime", "label": "Actual Check-in", "reqd": 1},
    {"fieldname": "section_id", "fieldtype": "Section Break", "label": "Guest ID"},
    {"fieldname": "id_type", "fieldtype": "Select", "label": "ID Type", "reqd": 1,
      "options": "\nPassport\nNational ID\nDriving License\nOther"},
    {"fieldname": "id_number", "fieldtype": "Data", "label": "ID Number", "reqd": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "id_expiry", "fieldtype": "Date", "label": "ID Expiry"},
    {"fieldname": "id_scan", "fieldtype": "Attach", "label": "ID Scan"},
    {"fieldname": "section_info", "fieldtype": "Section Break", "label": "Check-in Info"},
    {"fieldname": "key_issued", "fieldtype": "Check", "label": "Key Issued"},
    {"fieldname": "welcomed_by", "fieldtype": "Link", "label": "Welcomed By", "options": "Employee"},
    {"fieldname": "col_break_3", "fieldtype": "Column Break"},
    {"fieldname": "folio", "fieldtype": "Link", "label": "Guest Folio", "options": "Guest Folio", "read_only": 1},
    {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Check-in Remarks"}
  ],
  "permissions": [
    {"role": "Hotel Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
    {"role": "Hotel User", "read": 1, "write": 1, "create": 1, "submit": 1}
  ],
  "track_changes": 1
}
