{
  "name": "Hotel Booking",
  "module": "Hotel",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "HB-.YYYY.-.#####",
  "title_field": "guest",
  "search_fields": "guest,room_type,status,check_in_date",
  "fields": [
    {"fieldname": "booking_no", "fieldtype": "Data", "label": "Booking No", "read_only": 1, "in_list_view": 1},
    {"fieldname": "guest", "fieldtype": "Link", "label": "Guest", "reqd": 1, "options": "Guest", "in_list_view": 1,
      "in_standard_filter": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1, "in_list_view": 1,
      "options": "Enquiry\nConfirmed\nChecked In\nChecked Out\nCancelled\nNo Show",
      "default": "Enquiry"},
    {"fieldname": "company", "fieldtype": "Link", "label": "Company", "reqd": 1, "options": "Company"},
    {"fieldname": "section_room", "fieldtype": "Section Break", "label": "Room Details"},
    {"fieldname": "room_type", "fieldtype": "Link", "label": "Room Type", "reqd": 1, "options": "Room Type"},
    {"fieldname": "room", "fieldtype": "Link", "label": "Room Assigned", "options": "Room"},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "rate_plan", "fieldtype": "Link", "label": "Rate Plan", "options": "Rate Plan"},
    {"fieldname": "nightly_rate", "fieldtype": "Currency", "label": "Nightly Rate", "read_only": 1},
    {"fieldname": "section_dates", "fieldtype": "Section Break", "label": "Dates"},
    {"fieldname": "check_in_date", "fieldtype": "Date", "label": "Check-in Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "check_out_date", "fieldtype": "Date", "label": "Check-out Date", "reqd": 1},
    {"fieldname": "num_nights", "fieldtype": "Int", "label": "Nights", "read_only": 1},
    {"fieldname": "col_break_3", "fieldtype": "Column Break"},
    {"fieldname": "num_adults", "fieldtype": "Int", "label": "Adults", "reqd": 1, "default": "1"},
    {"fieldname": "num_children", "fieldtype": "Int", "label": "Children", "default": "0"},
    {"fieldname": "section_source", "fieldtype": "Section Break", "label": "Booking Source"},
    {"fieldname": "booking_source", "fieldtype": "Select", "label": "Booking Source", "reqd": 1,
      "options": "\nWalk-in\nPhone\nWebsite\nOTA\nCorporate\nTravel Agent"},
    {"fieldname": "ota_reference", "fieldtype": "Data", "label": "OTA Reference",
      "depends_on": "eval:doc.booking_source === 'OTA'"},
    {"fieldname": "col_break_4", "fieldtype": "Column Break"},
    {"fieldname": "advance_paid", "fieldtype": "Currency", "label": "Advance Paid", "read_only": 1},
    {"fieldname": "special_requests", "fieldtype": "Text", "label": "Special Requests"}
  ],
  "permissions": [
    {"role": "Hotel Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "Hotel User", "read": 1, "write": 1, "create": 1, "submit": 1}
  ],
  "track_changes": 1,
  "sort_field": "check_in_date",
  "sort_order": "ASC"
}
