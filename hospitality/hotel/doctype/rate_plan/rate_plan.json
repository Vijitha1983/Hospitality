{
  "name": "Rate Plan",
  "module": "Hotel",
  "doctype": "DocType",
  "is_submittable": 0,
  "autoname": "field:plan_name",
  "title_field": "plan_name",
  "fields": [
    {"fieldname": "plan_name", "fieldtype": "Data", "label": "Plan Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "plan_type", "fieldtype": "Select", "label": "Plan Type", "reqd": 1, "in_list_view": 1,
      "options": "\nSeasonal\nCorporate\nPackage\nPromotional\nGroup"},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "linked_customer", "fieldtype": "Link", "label": "Linked Customer", "options": "Customer",
      "depends_on": "eval:in_list(['Corporate','Group'], doc.plan_type)"},
    {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"},
    {"fieldname": "section_validity", "fieldtype": "Section Break", "label": "Validity"},
    {"fieldname": "valid_from", "fieldtype": "Date", "label": "Valid From", "reqd": 1},
    {"fieldname": "valid_to", "fieldtype": "Date", "label": "Valid To", "reqd": 1},
    {"fieldname": "section_rates", "fieldtype": "Section Break", "label": "Room Rates"},
    {"fieldname": "room_rates", "fieldtype": "Table", "label": "Room Rates", "reqd": 1,
      "options": "Rate Plan Room Rate"},
    {"fieldname": "section_inclusions", "fieldtype": "Section Break", "label": "Inclusions"},
    {"fieldname": "includes_breakfast", "fieldtype": "Check", "label": "Includes Breakfast"},
    {"fieldname": "includes_dinner", "fieldtype": "Check", "label": "Includes Dinner"},
    {"fieldname": "cancellation_policy", "fieldtype": "Text", "label": "Cancellation Policy"}
  ],
  "permissions": [
    {"role": "Hotel Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Hotel User", "read": 1}
  ],
  "track_changes": 1
}
