    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "floor", "fieldtype": "Int", "label": "Floor", "reqd": 1},
    {"fieldname": "wing", "fieldtype": "Data", "label": "Wing / Block"},
    {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"},
    {"fieldname": "section_status", "fieldtype": "Section Break", "label": "Current Status"},
    {"fieldname": "current_status", "fieldtype": "Select", "label": "Current Status", "reqd": 1, "in_list_view": 1,
