    {"fieldname": "last_cleaned", "fieldtype": "Datetime", "label": "Last Cleaned", "read_only": 1},
    {"fieldname": "assigned_hk", "fieldtype": "Link", "label": "Assigned Housekeeper", "options": "Employee"},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Internal Notes"}
