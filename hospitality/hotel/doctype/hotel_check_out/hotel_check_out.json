{
  "name": "Hotel Check-out",
  "module": "Hotel",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "CO-.YYYY.-.#####",
  "title_field": "guest",
  "fields": [
    {"fieldname": "booking", "fieldtype": "Link", "label": "Booking", "reqd": 1, "options": "Hotel Booking", "in_list_view": 1},
    {"fieldname": "guest", "fieldtype": "Link", "label": "Guest", "reqd": 1, "options": "Guest", "read_only": 1, "in_list_view": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "room", "fieldtype": "Link", "label": "Room", "reqd": 1, "options": "Room"},
    {"fieldname": "folio", "fieldtype": "Link", "label": "Guest Folio", "reqd": 1, "options": "Guest Folio"},
    {"fieldname": "section_amounts", "fieldtype": "Section Break", "label": "Settlement"},
    {"fieldname": "actual_checkout", "fieldtype": "Datetime", "label": "Actual Check-out", "reqd": 1},
    {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Folio Amount", "reqd": 1, "read_only": 1},
    {"fieldname": "advance_adjusted", "fieldtype": "Currency", "label": "Advance Adjusted", "read_only": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "net_payable", "fieldtype": "Currency", "label": "Net Payable", "reqd": 1, "read_only": 1},
    {"fieldname": "settlement_mode", "fieldtype": "Select", "label": "Settlement Mode", "reqd": 1,
      "options": "\nCash\nCredit Card\nUPI\nBank Transfer\nDirect Bill\nComplimentary"},
    {"fieldname": "section_refs", "fieldtype": "Section Break", "label": "References"},
    {"fieldname": "invoice", "fieldtype": "Link", "label": "Sales Invoice", "options": "Sales Invoice", "read_only": 1},
    {"fieldname": "payment_entry", "fieldtype": "Link", "label": "Payment Entry", "options": "Payment Entry", "read_only": 1},
    {"fieldname": "checked_out_by", "fieldtype": "Link", "label": "Checked Out By", "options": "Employee"}
  ],
  "permissions": [
    {"role": "Hotel Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
    {"role": "Hotel User", "read": 1, "write": 1, "create": 1, "submit": 1}
  ],
  "track_changes": 1
}
