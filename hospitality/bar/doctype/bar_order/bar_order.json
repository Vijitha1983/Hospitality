{
  "name": "Bar Order",
  "module": "Bar",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "BORD-.YYYY.-.#####",
  "title_field": "tab",
  "fields": [
    {"fieldname": "order_no", "fieldtype": "Data", "label": "Order No", "read_only": 1, "in_list_view": 1},
    {"fieldname": "tab", "fieldtype": "Link", "label": "Bar Tab", "reqd": 1, "options": "Bar Tab", "in_list_view": 1},
    {"fieldname": "outlet", "fieldtype": "Link", "label": "Outlet", "reqd": 1, "options": "Outlet"},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "order_time", "fieldtype": "Datetime", "label": "Order Time", "reqd": 1},
    {"fieldname": "served_by", "fieldtype": "Link", "label": "Served By", "options": "Employee"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1, "in_list_view": 1,
      "options": "Pending\nBOT Sent\nPreparing\nServed\nCancelled", "default": "Pending"},
    {"fieldname": "section_items", "fieldtype": "Section Break", "label": "Items"},
    {"fieldname": "items", "fieldtype": "Table", "label": "Items", "reqd": 1, "options": "Bar Order Item"},
    {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total", "reqd": 1, "read_only": 1},
    {"fieldname": "bot", "fieldtype": "Link", "label": "BOT", "options": "BOT", "read_only": 1}
  ],
  "permissions": [
    {"role": "Bar Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
    {"role": "Bar User", "read": 1, "write": 1, "create": 1, "submit": 1}
  ],
  "track_changes": 1
}
