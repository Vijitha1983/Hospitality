{
  "name": "Table Reservation",
  "module": "Restaurant",
  "doctype": "DocType",
  "is_submittable": 0,
  "autoname": "naming_series:",
  "naming_series": "RES-.YYYY.-.#####",
  "title_field": "guest_name",
  "search_fields": "guest_name,phone,reservation_date,status",
  "fields": [
    {"fieldname": "reservation_no", "fieldtype": "Data", "label": "Reservation No", "read_only": 1, "in_list_view": 1},
    {"fieldname": "outlet", "fieldtype": "Link", "label": "Outlet", "reqd": 1, "options": "Outlet"},
    {"fieldname": "guest", "fieldtype": "Link", "label": "Guest (Existing)", "options": "Guest"},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "guest_name", "fieldtype": "Data", "label": "Guest Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "phone", "fieldtype": "Data", "label": "Phone", "reqd": 1},
    {"fieldname": "email", "fieldtype": "Data", "label": "Email", "options": "Email"},
    {"fieldname": "section_booking", "fieldtype": "Section Break", "label": "Reservation Details"},
    {"fieldname": "reservation_date", "fieldtype": "Date", "label": "Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "reservation_time", "fieldtype": "Time", "label": "Time", "reqd": 1, "in_list_view": 1},
    {"fieldname": "num_covers", "fieldtype": "Int", "label": "Covers", "reqd": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "table", "fieldtype": "Link", "label": "Table", "options": "Dining Table"},
    {"fieldname": "section_preference", "fieldtype": "Link", "label": "Section Preference", "options": "Table Section"},
    {"fieldname": "occasion", "fieldtype": "Select", "label": "Occasion",
      "options": "\nBirthday\nAnniversary\nBusiness\nCasual\nOther"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1, "in_list_view": 1,
      "options": "Confirmed\nSeated\nCompleted\nCancelled\nNo Show\nWaitlisted", "default": "Confirmed"},
    {"fieldname": "special_notes", "fieldtype": "Text", "label": "Special Notes"},
    {"fieldname": "confirmation_sent", "fieldtype": "Check", "label": "Confirmation Sent"}
  ],
  "permissions": [
    {"role": "Restaurant Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Restaurant User", "read": 1, "write": 1, "create": 1}
  ],
  "track_changes": 1,
  "sort_field": "reservation_date",
  "sort_order": "ASC"
}
