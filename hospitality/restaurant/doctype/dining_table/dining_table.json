    {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"},
    {"fieldname": "section_status", "fieldtype": "Section Break", "label": "Status"},
    {"fieldname": "current_status", "fieldtype": "Select", "label": "Status", "reqd": 1, "in_list_view": 1,
