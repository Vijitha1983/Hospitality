{
  "name": "Dining Table",
  "module": "Restaurant",
  "doctype": "DocType",
  "is_submittable": 0,
  "autoname": "field:table_number",
  "title_field": "table_number",
  "fields": [
    {"fieldname": "table_number", "fieldtype": "Data", "label": "Table Number", "reqd": 1, "in_list_view": 1},
    {"fieldname": "outlet", "fieldtype": "Link", "label": "Outlet", "reqd": 1, "options": "Outlet", "in_list_view": 1},
    {"fieldname": "section", "fieldtype": "Link", "label": "Section", "reqd": 1, "options": "Table Section"},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "seating_capacity", "fieldtype": "Int", "label": "Seating Capacity", "reqd": 1},
    {"fieldname": "table_shape", "fieldtype": "Select", "label": "Table Shape",
