    {"fieldname": "section_layout", "fieldtype": "Section Break", "label": "Floor Plan Position"},
    {"fieldname": "pos_x", "fieldtype": "Float", "label": "X Position"},
    {"fieldname": "pos_y", "fieldtype": "Float", "label": "Y Position"}
