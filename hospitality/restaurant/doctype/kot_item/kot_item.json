{
  "name": "KOT Item",
  "module": "Restaurant",
  "doctype": "DocType",
  "istable": 1,
  "fields": [
    {"fieldname": "menu_item", "fieldtype": "Link", "label": "Menu Item", "reqd": 1, "options": "Menu Item", "in_list_view": 1},
    {"fieldname": "item_name", "fieldtype": "Data", "label": "Item Name", "reqd": 1, "read_only": 1, "in_list_view": 1},
    {"fieldname": "qty", "fieldtype": "Float", "label": "Qty", "reqd": 1, "default": "1", "in_list_view": 1},
    {"fieldname": "rate", "fieldtype": "Currency", "label": "Rate", "reqd": 1, "in_list_view": 1},
    {"fieldname": "amount", "fieldtype": "Currency", "label": "Amount", "reqd": 1, "read_only": 1, "in_list_view": 1},
    {"fieldname": "course", "fieldtype": "Select", "label": "Course",
      "options": "\nStarter\nMain Course\nDessert"},
    {"fieldname": "modifiers", "fieldtype": "Data", "label": "Modifiers"},
    {"fieldname": "special_instructions", "fieldtype": "Text", "label": "Chef Notes"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1,
      "options": "Pending\nIn Preparation\nReady\nServed\nVoid", "default": "Pending", "in_list_view": 1},
    {"fieldname": "void_reason", "fieldtype": "Data", "label": "Void Reason", "depends_on": "eval:doc.status==='Void'"},
    {"fieldname": "void_by", "fieldtype": "Link", "label": "Voided By", "options": "Employee",
      "depends_on": "eval:doc.status==='Void'"}
  ]
}
